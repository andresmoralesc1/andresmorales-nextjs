# --- Brevo (transactional email API) ---------------------------------------
# Source: ux-ai-emailer account (single Brevo account covers both projects)
BREVO_API_KEY=your_brevo_api_key_here

# Where briefs land
BRIEF_TO_EMAIL=info@andresmorales.com.co

# Who they appear to come from (display name shown in Gmail)
# Sender andres@andresmorales.com.co must be verified in Brevo
BRIEF_FROM_EMAIL=andres@andresmorales.com.co
BRIEF_FROM_NAME=Andrés Morales

# --- ClickUp integration ---------------------------------------------------
# Every brief also creates a task here so it lands in the pipeline board
# alongside your other work.
# Token: ClickUp → Settings → Apps → API
CLICKUP_API_TOKEN=pk_your_clickup_token_here
# List ID of the "New -- awaiting review" list (see README for setup)
CLICKUP_BRIEF_LIST_ID=900000000000

# --- Analytics (optional) --------------------------------------------------
# Plausible — cookieless, GDPR-friendly analytics. Sign up at https://plausible.io
# (or self-host), add the site (e.g. portafolio.andresmorales.com.co), and
# paste the exact domain name below. When unset, the Plausible <script>
# tag is omitted from the page and events flow only to the in-app
# CustomEvent dispatcher + console.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
